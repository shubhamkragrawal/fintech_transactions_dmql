[sqlfluff]
templater = dbt
dialect = postgres
max_line_length = 150

ignore = target/,dbt_packages/

# Exclude strict rules that conflict with our coding style
exclude_rules =
    capitalisation.keywords,
    capitalisation.identifiers,
    layout.spacing,
    layout.indent,
    layout.end_of_file,
    aliasing.table,
    structure.column_order,
    convention.casting_style

[sqlfluff:templater:dbt]
project_dir = .
profiles_dir = .
