  create  table "postgres"."analytics_analytics"."dim_customer__dbt_tmp"
  
  
    as
  
  (
    -- dim_customer.sql
-- Final customer dimension for the Star Schema

with customers as (
    select * from "postgres"."analytics_staging"."stg_customers"
)

select
    customer_id,
    full_name,
    date_of_birth,
    gender,
    region,
    email,
    status,
    join_date,
    -- Derived: customer age bucket
    case
        when date_of_birth is null then 'Unknown'
        when date_part('year', age(date_of_birth::date)) < 25 then '18-24'
        when date_part('year', age(date_of_birth::date)) < 35 then '25-34'
        when date_part('year', age(date_of_birth::date)) < 50 then '35-49'
        when date_part('year', age(date_of_birth::date)) < 65 then '50-64'
        else '65+'
    end as age_bucket
from customers
  );
  
